# Copy to /etc/cineco.env (chmod 600) on the server.
TMDB_API_KEY=your_tmdb_key_here
# Public URL where feed.xml is served (GitHub Pages).
FEED_URL=https://example.github.io/cinecolombia-check/feed.xml
# Optional feed title override.
# FEED_TITLE=CineColombia — Cartelera y Preventa
# Set to 1 to enable git commit+push after a successful scrape.
CINECO_GIT_PUSH=1
# Optional: POST lifecycle transitions (added, preventa, in-theaters, removed)
# to this Discord webhook URL. One rich embed per event, after files are saved.
# NOTIFY_WEBHOOK_URL=https://discord.com/api/webhooks/...
